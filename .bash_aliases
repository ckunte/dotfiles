# Interactive options
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
# Default to human readable units
alias df='df -h'
alias du='du -h'
# Misc
alias grep='grep --color'
# Listing
alias l='ls -Al --color=auto' # long list w/o . and .. folders
alias ll='ls -al --color=auto'
# Housekeeping toolkit
alias hk='make --file=~/scripts/hkp/hkp.make'
